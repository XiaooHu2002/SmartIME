<idea-plugin>
    <!--
      说明：JetBrains 插件基础元信息。
      当前插件是 SmartIME 在 JetBrains 平台上的适配层，负责把 IDE 场景事件转换成统一输入法意图。
    -->
    <id>cn.xiaoo.smartime.jetbrains</id>
    <name>SmartIME</name>
    <vendor email="xiaoo@example.com" url="https://cnb.cool/qianyios/SmartIME">XiaooHu</vendor>
    <description><![CDATA[
        SmartIME JetBrains 适配层。
        通过 Go Worker 完成输入法状态切换与查询，适配默认场景、注释场景、字符串场景、Git 提交、工具窗口、IdeaVim 等。
    ]]></description>

    <idea-version since-build="211" until-build="999.*"/>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!--
          说明：在 IDE 启动后尽早注册监听器，确保场景识别在用户进入编辑器前后都可生效。
        -->
        <postStartupActivity implementation="cn.xiaoo.smartime.SmartImeStartupActivity"/>
        <!--
          说明：项目级设置页面，集中配置 SmartIME 场景策略与调试选项。
        -->
        <projectConfigurable
                id="cn.xiaoo.smartime.settings"
                displayName="SmartIME"
                instance="cn.xiaoo.smartime.SmartImeProjectConfigurable"/>
        <statusBarWidgetFactory implementation="cn.xiaoo.smartime.SmartImeStatusBarWidgetFactory"/>
    </extensions>

    <actions>
        <action id="SmartIME.ShowMenu" class="cn.xiaoo.smartime.SmartImeShowMenuAction" text="SmartIME 菜单">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="SmartIME.ToggleAutoSwitch" class="cn.xiaoo.smartime.SmartImeToggleAutoSwitchAction" text="SmartIME: 自动切换开关">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="SmartIME.SwitchToChinese" class="cn.xiaoo.smartime.SmartImeSwitchToChineseAction" text="SmartIME: 切换到中文">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="SmartIME.SwitchToEnglish" class="cn.xiaoo.smartime.SmartImeSwitchToEnglishAction" text="SmartIME: 切换到英文">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
